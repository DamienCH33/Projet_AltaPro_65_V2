<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Alta Pro 65
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
			<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
			<link rel="stylesheet" href="{{ asset('styles/style.css') }}">
		{% endblock %}

		{% block javascripts %}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
		<script src="{{ asset('script.js') }}" defer></script>{% endblock %}
	</head>
	<body class="altapro"> 
		<header>
			<nav class="navbar custom-navbar navbar-expand-lg">
				<div class="navbar-container">
					<div class="logo">
						<a href="{{path ('app_home') }}">
							<img src="{{ asset('/images/logo vectorise.jpg') }}" alt="Logo de l'entreprise">
							<span>Alta Pro 65</span>
						</a>
					</div>

					<div class="collapse navbar-collapse justify-content-end" id="navbarNav">
						<ul class="nav-links navbar-nav">
							<li class="nav-item">
								<a class="nav-link" href="{{path ('app_home') }}">Accueil</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{path ('app_services') }}">Nos Services</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{path ('app_realisations') }}">Nos Réalisations</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{path ('app_about') }}">À Propos</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{path ('app_contact') }}">Contact</a>
							</li>
						</ul>
					</div>
				</div>
			</nav>
		</header>
		{% block body %}{% endblock %}

		<footer class="footer bg-light mt-4">
			<div class="container text-center">
				<div class="row justify-content-between">
					<div class="col-4">
						&copy; 2025 Alta Pro 65. Tous droits réservés.
					</div>
					<div class="col-8">
						<a href="{{path ('app_home') }}" class="social-icon">Accueil</a>
						<a href="{{path ('app_services') }}" class="social-icon">Nos Services</a>
						<a href="{{path ('app_realisations') }}" class="social-icon">Nos Réalisations</a>
						<a href="{{path ('app_about') }}" class="social-icon">À Propos</a>
						<a href="{{path ('app_contact') }}" class="social-icon">Contact</a>
					</div>
				</div>
			</div>
		</footer>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>


	</body>
</html>
